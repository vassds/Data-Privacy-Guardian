{
  "name": "data-privacy-guardian",
  "version": "1.0.0",
  "description": "Enterprise-grade performant privacy browser extension",
  "scripts": {
    "build:wasm": "cd ../core && wasm-pack build --target web --release",
    "build:ext": "webpack --config webpack.config.js --mode production",
    "build": "npm run build:wasm && npm run build:ext",
    "watch": "webpack --config webpack.config.js --mode development --watch"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.12.5",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
